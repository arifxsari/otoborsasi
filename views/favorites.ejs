<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Favorilerim - OtoBorsası</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-950 text-gray-200">

    <nav class="bg-slate-900 text-white shadow-lg border-b border-slate-800">
        <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <span class="text-2xl font-bold text-red-500">OtoBorsası</span>
            <a href="/" class="hover:text-red-400 transition font-semibold">Ana Sayfaya Dön</a>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 py-10">
        <div class="flex justify-between items-center mb-6 border-b border-slate-800 pb-4">
            <h2 class="text-3xl font-bold text-white">🤍 Favori İlanlarım</h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6">
            <% if (listings.length > 0) { %>
                <% listings.forEach(function(listing) { %>
                    <div class="bg-slate-900 rounded-lg shadow-xl border border-slate-800 overflow-hidden hover:border-red-600 transition flex flex-col relative">
                        <div class="relative">
                            <img src="<%= listing.images.split(',')[0] %>" class="w-full h-48 object-cover">
                            <a href="/toggle-favorite/<%= listing.id %>" class="absolute top-2 right-2 bg-slate-900/80 p-2 rounded-full hover:bg-slate-800 transition shadow-lg z-10">
                                <span class="text-xl leading-none">❤️</span>
                            </a>
                        </div>

                        <div class="p-4 flex-grow flex flex-col justify-between">
                            <div>
                                <h2 class="text-lg font-bold text-white"><%= listing.brand %> <%= listing.model %></h2>
                                <p class="text-gray-400 text-sm mb-1"><%= listing.year %> Model • <%= listing.mileage.toLocaleString('tr-TR') %> KM</p>
                                <p class="text-red-400 text-xs font-semibold mb-3">📍 <%= listing.city %> / <%= listing.district %></p>
                            </div>
                            <div class="flex justify-between items-center mt-4 border-t border-slate-800 pt-4">
                                <span class="text-xl font-extrabold text-white"><%= listing.price.toLocaleString('tr-TR') %> ₺</span>
                                <a href="/listing/<%= listing.id %>" class="bg-slate-800 text-red-400 border border-slate-700 hover:bg-red-600 hover:text-white text-sm font-semibold py-2 px-3 rounded transition">İncele</a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-span-full bg-slate-900 p-10 text-center rounded-lg shadow-xl border border-slate-800 border-dashed">
                    <p class="text-gray-500 text-lg mb-4">Henüz favorilerinize hiç araç eklemediniz.</p>
                    <a href="/" class="text-red-500 font-bold hover:underline">Vitrine dön ve araçları incele!</a>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>