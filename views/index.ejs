    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const links = document.querySelectorAll('.transition-link');
            const mainContent = document.getElementById('main-content');

            links.forEach(link => {
                link.addEventListener('click', function(e) {
                    // Eğer link yeni sekmede açılacaksa veya boşsa engelleme
                    if (this.target === '_blank' || !this.href || this.href.includes('#')) return;
                    
                    e.preventDefault(); // Anında geçişi durdur
                    const targetUrl = this.href;

                    // Çıkış animasyonu ayarları (Hafifçe kararır ve aşağı kayar)
                    mainContent.style.transition = 'all 0.3s ease-in';
                    mainContent.style.opacity = '0';
                    mainContent.style.transform = 'translateY(10px)';

                    // Animasyon bittiğinde (300ms sonra) yeni sayfaya yönlendir
                    setTimeout(() => {
                        window.location.href = targetUrl;
                    }, 300);
                });
            });
        });
    </script>
