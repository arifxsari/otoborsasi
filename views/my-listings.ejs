<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>İlanlarım - OtoBorsası</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-950 text-gray-200">
    <nav class="bg-slate-900 text-white p-4 border-b border-slate-800">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <a href="/" class="text-2xl font-bold text-red-500">OtoBorsası</a>
            <div class="flex items-center space-x-4">
                <a href="/add-listing" class="bg-red-600 hover:bg-red-700 text-white px-3 py-2 rounded text-sm font-bold shadow">+ Yeni İlan Ekle</a>
                <a href="/" class="hover:text-red-400 transition">Ana Sayfa'ya Dön</a>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 py-10">
        <h2 class="text-3xl font-bold text-white mb-8 border-l-4 border-red-600 pl-4">📂 Kendi İlanlarım Yönetim Paneli</h2>

        <% if (listings.length === 0) { %>
            <div class="bg-slate-900 p-10 rounded-xl shadow border-dashed border-2 border-slate-700 text-center">
                <p class="text-gray-400 text-lg mb-4">Henüz hiç ilan vermediniz.</p>
                <a href="/add-listing" class="bg-red-600 hover:bg-red-700 text-white px-6 py-2 rounded-lg font-bold transition inline-block">İlk İlanını Ver</a>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% listings.forEach(function(listing) { %>
                    <div class="bg-slate-900 rounded-xl shadow-xl border border-slate-800 overflow-hidden flex flex-col">
                        <img src="<%= listing.images.split(',')[0] %>" class="w-full h-48 object-cover">
                        <div class="p-5 flex-grow flex flex-col justify-between">
                            <div>
                                <h2 class="text-lg font-bold text-white"><%= listing.brand %> <%= listing.model %></h2>
                                <p class="text-gray-400 text-sm mb-2"><%= listing.year %> Model • <%= listing.mileage.toLocaleString('tr-TR') %> KM</p>
                                <span class="text-xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400"><%= listing.price.toLocaleString('tr-TR') %> ₺</span>
                            </div>
                            
                            <div class="mt-4 border-t border-slate-800 pt-4 flex space-x-2">
                                <a href="/edit-listing/<%= listing.id %>" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white text-center text-sm font-semibold py-2 rounded-lg transition shadow">✏️ Düzenle</a>
                                <a href="/delete-my-listing/<%= listing.id %>" onclick="return confirm('Bu ilanı kalıcı olarak silmek istediğinize emin misiniz?')" class="flex-1 bg-slate-800 hover:bg-red-600 text-gray-300 hover:text-white border border-slate-700 hover:border-red-600 text-center text-sm font-semibold py-2 rounded-lg transition shadow">🗑️ Sil</a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>
</body>
</html>